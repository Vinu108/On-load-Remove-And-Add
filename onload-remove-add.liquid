 <script>
       const observer = new MutationObserver(() => {
  const btn = document.querySelector('#mu-checkout-button');

  if (btn) {
    // Remove all attributes
    [...btn.attributes].forEach(attr => btn.removeAttribute(attr.name));

    // Set only custom class
    btn.setAttribute('class', 'custom_checkout');
  }
});

observer.observe(document.body, {
  childList: true,
  subtree: true
});
      </script>
